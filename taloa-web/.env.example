# ════════════════════════════════════════════════════════════
# taloa-web — Variaveis de ambiente (Next.js / Vercel)
# Copie para .env.local e preencha. NUNCA commite o .env.local.
# Tudo que comeca com NEXT_PUBLIC_ fica visivel no browser.
# ════════════════════════════════════════════════════════════

# ── API (FastAPI no Railway) ─────────────────────────────────
# Base URL do backend. O frontend consome TUDO daqui.
NEXT_PUBLIC_API_URL=http://localhost:8000           # prod: https://api.taloa.ie

# ── SUPABASE (somente Auth + Storage no cliente) ─────────────
# Usado apenas para login (Auth) e upload de fotos (Storage).
# NUNCA colocar a service_role_key aqui — ela vive so no taloa-api.
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx...

# ── APP ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://taloa.ie
NEXT_PUBLIC_APP_NAME=TALOA
NEXT_PUBLIC_TAG_PREFIX=TAL

# ── GOOGLE MAPS — EMERGENCY DIRECTORY ────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaxxx...

# ── SENTRY — MONITORAMENTO (opcional) ────────────────────────
NEXT_PUBLIC_SENTRY_DSN=

# ── POSTHOG — ANALYTICS (opcional) ───────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
