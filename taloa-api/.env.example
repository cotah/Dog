# ════════════════════════════════════════════════════════════
# taloa-api — Variaveis de ambiente (FastAPI / Railway)
# Copie para .env e preencha. NUNCA commite o .env.
# ════════════════════════════════════════════════════════════

# ── SUPABASE ──────────────────────────────────────────────────
# Acesso ao banco PostgreSQL + Storage (server-side, service role)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJxxx...
SUPABASE_SERVICE_ROLE_KEY=eyJxxx...      # NUNCA expor no frontend
SUPABASE_JWT_SECRET=your-jwt-secret       # usado para VALIDAR o JWT do Supabase Auth

# ── APP ───────────────────────────────────────────────────────
APP_NAME=TALOA
APP_ENV=development                       # development | production
TAG_PREFIX=TAL
FRONTEND_URL=https://taloa.ie
# Origens permitidas no CORS (separadas por virgula)
ALLOWED_ORIGINS=http://localhost:3000,https://taloa.ie

# ── ANTHROPIC — AGENTE DE IA ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx...
ANTHROPIC_MODEL=claude-sonnet-4-6
AI_MAX_MESSAGES_PER_SESSION=20            # rate limit do chat por sessao

# ── RESEND — EMAIL ────────────────────────────────────────────
RESEND_API_KEY=re_xxx...
RESEND_FROM_EMAIL=hello@taloa.ie

# ── SENTRY — MONITORAMENTO (opcional) ────────────────────────
SENTRY_DSN=
